<?xml version="1.0" encoding="utf-8"?>
<!-- 320x180 TV launcher banner. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#1B2A4A"
                android:endColor="#4F8CFF" />
        </shape>
    </item>
    <item
        android:left="120dp"
        android:top="55dp"
        android:right="120dp"
        android:bottom="55dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
